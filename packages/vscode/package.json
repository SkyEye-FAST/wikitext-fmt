{
  "activationEvents": [
    "onLanguage:wikitext",
    "onLanguage:mediawiki"
  ],
  "categories": [
    "Formatters"
  ],
  "keywords": [
    "wikitext",
    "mediawiki",
    "wiki",
    "formatter",
    "formatting"
  ],
  "qna": false,
  "pricing": "Free",
  "galleryBanner": {
    "color": "#2f3340",
    "theme": "dark"
  },
  "contributes": {
    "commands": [
      {
        "command": "wikitext-fmt.formatDocument",
        "title": "Wikitext Formatter: Format Document"
      }
    ],
    "configuration": {
      "properties": {
        "wikitextFmt.formatReferences": {
          "default": false,
          "description": "Enable experimental reference formatting.",
          "type": "boolean"
        },
        "wikitextFmt.formatSectionSpacing": {
          "default": false,
          "description": "Enable experimental section spacing formatting.",
          "type": "boolean"
        },
        "wikitextFmt.formatTables": {
          "default": false,
          "description": "Enable experimental table formatting.",
          "type": "boolean"
        },
        "wikitextFmt.formatTemplateParameters": {
          "default": false,
          "description": "Enable experimental multiline template parameter formatting.",
          "type": "boolean"
        },
        "wikitextFmt.htmlVoidTagStyle": {
          "default": "html5",
          "description": "HTML void tag style.",
          "enum": [
            "html5",
            "xhtml",
            "preserve"
          ],
          "type": "string"
        },
        "wikitextFmt.level": {
          "default": "normal",
          "description": "Formatter rule level.",
          "enum": [
            "safe",
            "normal",
            "experimental"
          ],
          "type": "string"
        },
        "wikitextFmt.safe": {
          "default": true,
          "description": "Run with parse and idempotency safety checks.",
          "type": "boolean"
        },
        "wikitextFmt.config.enabled": {
          "default": true,
          "description": "Load wikitext-fmt configuration files for workspace/file documents.",
          "type": "boolean"
        },
        "wikitextFmt.config.path": {
          "default": null,
          "description": "Explicit wikitext-fmt configuration file path. Relative paths are resolved from the workspace folder when available.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "title": "Wikitext Formatter"
    },
    "languages": [
      {
        "aliases": [
          "Wikitext",
          "wikitext",
          "MediaWiki"
        ],
        "extensions": [
          ".wiki",
          ".wikitext",
          ".mediawiki"
        ],
        "id": "wikitext"
      }
    ]
  },
  "dependencies": {
    "wikitext-fmt": "workspace:*"
  },
  "description": "Conservative MediaWiki wikitext formatter for VS Code",
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "displayName": "Wikitext Formatter",
  "engines": {
    "vscode": "^1.90.0"
  },
  "license": "GPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/SkyEye-FAST/wikitext-fmt/issues"
  },
  "homepage": "https://github.com/SkyEye-FAST/wikitext-fmt#readme",
  "main": "./dist/extension.js",
  "name": "wikitext-formatter",
  "publisher": "skyeyefast",
  "repository": {
    "type": "git",
    "url": "https://github.com/SkyEye-FAST/wikitext-fmt.git",
    "directory": "packages/vscode"
  },
  "scripts": {
    "build": "pnpm --filter wikitext-fmt build && node scripts/build.mjs",
    "check:package-content": "node scripts/check-package-content.mjs",
    "check:release": "pnpm typecheck && pnpm build && pnpm test && pnpm check:package-content && pnpm vscode:package",
    "package": "pnpm vscode:package",
    "test": "vitest run",
    "test:extension": "pnpm build && tsc -p tsconfig.test.json && node dist-test/test/runTest.js",
    "test:vsix": "pnpm vscode:package && tsc -p tsconfig.test.json && node scripts/test-vsix.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "vscode:package": "pnpm build && vsce package --no-dependencies"
  },
  "type": "module",
  "version": "0.1.0"
}
