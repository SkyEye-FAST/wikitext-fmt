{
  "activationEvents": [
    "onLanguage:wikitext",
    "onLanguage:mediawiki"
  ],
  "categories": [
    "Formatters"
  ],
  "contributes": {
    "commands": [
      {
        "command": "wikitext-fmt.formatDocument",
        "title": "wikitext-fmt: Format Document"
      }
    ],
    "configuration": {
      "properties": {
        "wikitextFmt.formatReferences": {
          "default": false,
          "description": "Enable experimental reference formatting.",
          "type": "boolean"
        },
        "wikitextFmt.formatSectionSpacing": {
          "default": false,
          "description": "Enable experimental section spacing formatting.",
          "type": "boolean"
        },
        "wikitextFmt.formatTables": {
          "default": false,
          "description": "Enable experimental table formatting.",
          "type": "boolean"
        },
        "wikitextFmt.formatTemplateParameters": {
          "default": false,
          "description": "Enable experimental multiline template parameter formatting.",
          "type": "boolean"
        },
        "wikitextFmt.htmlVoidTagStyle": {
          "default": "html5",
          "description": "HTML void tag style.",
          "enum": [
            "html5",
            "xhtml",
            "preserve"
          ],
          "type": "string"
        },
        "wikitextFmt.level": {
          "default": "normal",
          "description": "Formatter rule level.",
          "enum": [
            "safe",
            "normal",
            "experimental"
          ],
          "type": "string"
        },
        "wikitextFmt.safe": {
          "default": true,
          "description": "Run with parse and idempotency safety checks.",
          "type": "boolean"
        }
      },
      "title": "wikitext-fmt"
    },
    "languages": [
      {
        "aliases": [
          "Wikitext",
          "wikitext",
          "MediaWiki"
        ],
        "extensions": [
          ".wiki",
          ".wikitext",
          ".mediawiki"
        ],
        "id": "wikitext"
      }
    ]
  },
  "dependencies": {
    "wikitext-fmt": "workspace:*"
  },
  "description": "VS Code wrapper for the conservative wikitext-fmt formatter",
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "displayName": "wikitext-fmt",
  "engines": {
    "vscode": "^1.90.0"
  },
  "license": "GPL-3.0-or-later",
  "main": "./dist/extension.js",
  "name": "wikitext-fmt-vscode",
  "private": true,
  "publisher": "skyeye-fast",
  "repository": {
    "type": "git",
    "url": "https://github.com/SkyEye-FAST/wikitext-fmt.git",
    "directory": "packages/vscode"
  },
  "scripts": {
    "build": "pnpm --filter wikitext-fmt build && node scripts/build.mjs",
    "check:package-content": "node scripts/check-package-content.mjs",
    "package": "pnpm vscode:package",
    "test": "vitest run",
    "test:extension": "pnpm build && tsc -p tsconfig.test.json && node dist-test/test/runTest.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "vscode:package": "pnpm build && vsce package --no-dependencies"
  },
  "type": "module",
  "version": "0.1.0"
}
